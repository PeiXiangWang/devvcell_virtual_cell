{
  "project": "DevVCell response-recovery virtual cell",
  "version": "2026-05-05",
  "seed": 42,
  "mode_defaults": {
    "quick": "RDEG-derived proxy response-recovery classes for rapid regression checks",
    "main": "Embryo manifold plus one external perturbation dataset",
    "full": "Multi-system, multi-perturbation, ablation and external validation"
  },
  "input": {
    "embryo_h5ad": "data/scLine_pro.h5ad",
    "rdeg_proxy_dir": "data/rdeg_neural_cell_mvp",
    "devvcell_lite_tables_dir": "results/tables",
    "stage_column": "development_stage",
    "cell_type_column": "cell_type",
    "donor_column": "donor_id",
    "sex_column": "sex",
    "major_cluster_column": "author_major_cell_cluster"
  },
  "output": {
    "root": "results/response_recovery",
    "tables": "results/response_recovery/tables",
    "figures": "results/response_recovery/figures",
    "embryo_manifold_cells": "results/response_recovery/tables/embryo_manifold_cells.parquet",
    "stage_celltype_centroids": "results/response_recovery/tables/stage_celltype_centroids.parquet",
    "manifold_quality_metrics": "results/response_recovery/tables/manifold_quality_metrics.csv",
    "response_recovery_classes": "results/response_recovery/tables/response_recovery_classes.csv",
    "stage_vulnerability_response_recovery": "results/response_recovery/tables/stage_vulnerability_response_recovery.csv",
    "window_enrichment_statistics": "results/response_recovery/tables/window_enrichment_statistics.csv",
    "minimal_rescue_control_matrix": "results/response_recovery/tables/minimal_rescue_control_matrix.csv"
  },
  "stage_window_of_interest": {
    "name": "TS14-TS19",
    "min_stage": 14,
    "max_stage": 19
  },
  "manifold": {
    "systems": {
      "neural": ["neural", "neuron", "glia", "cns", "retinal"],
      "mesoderm": ["mesoderm", "somite", "myoblast", "chondrocyte", "osteoblast", "fibroblast"],
      "pgc_gonad": ["germ", "primordial germ", "gonad", "leydig", "sertoli"],
      "hematopoietic": ["erythroid", "hematopoietic", "blood", "megakaryocyte"]
    },
    "max_cells_total": 80000,
    "max_cells_per_stage_celltype": 400,
    "latent_dim": 50,
    "classifier_test_fraction": 0.25,
    "min_cells_per_centroid": 25
  },
  "classification_thresholds": {
    "delay_margin": 0.05,
    "fate_margin": 0.05,
    "off_manifold_quantile": 0.95,
    "off_manifold_multiplier": 1.25,
    "recovery_cost_high_quantile": 0.75
  },
  "quick_proxy": {
    "top_perturbations": 16,
    "response_scale": 0.65,
    "off_manifold_weight": 0.35,
    "delay_weight": 0.45,
    "fate_weight": 0.45,
    "rescue_weight": 0.40
  }
}
