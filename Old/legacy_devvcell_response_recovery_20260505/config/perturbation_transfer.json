{
  "project": "DevVCell perturbation-response transfer",
  "version": "2026-05-05",
  "seed": 42,
  "input": {
    "external_h5ad": "data/external/response_transfer/primary_perturbation.h5ad",
    "embryo_manifold_cells": "results/response_recovery/tables/embryo_manifold_cells.parquet",
    "stage_celltype_centroids": "results/response_recovery/tables/stage_celltype_centroids.parquet",
    "external_dataset_registry": "config/external_datasets.json"
  },
  "output": {
    "root": "results/perturbation_transfer",
    "tables": "results/perturbation_transfer/tables",
    "figures": "results/perturbation_transfer/figures",
    "external_response_dictionary": "results/perturbation_transfer/tables/external_response_dictionary.parquet",
    "external_response_metadata": "results/perturbation_transfer/tables/external_response_metadata.csv",
    "transferred_response_by_stage_celltype": "results/perturbation_transfer/tables/transferred_response_by_stage_celltype.parquet"
  },
  "external_schema": {
    "control_label": "NTC",
    "condition_column": "orig.ident",
    "perturbation_column": "orig.ident",
    "cell_type_column": "cell_type",
    "batch_column": "replicate",
    "time_column": "time",
    "dose_column": "dose"
  },
  "encoding": {
    "latent_dim": 50,
    "max_cells": 100000,
    "max_cells_per_condition": 5000,
    "min_cells_per_condition": 50,
    "feature_gene_limit": 3000
  },
  "ot_transfer": {
    "method": "entropic_sinkhorn",
    "epsilon": 0.12,
    "iterations": 150,
    "target_level": "stage_celltype",
    "fallback_method": "soft_nearest_centroid",
    "confidence_distance_quantile": 0.90
  },
  "ortholog_mapping": {
    "required_for_cross_species": true,
    "mouse_gene_column": "mouse_gene",
    "human_gene_column": "human_gene",
    "mapping_file": "data/external/orthologs/human_mouse_orthologs.tsv"
  }
}
