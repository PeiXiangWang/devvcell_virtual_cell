      "hidden_dim": 160,
      "epochs": 160,
      "batch_size": 512,
      "learning_rate": 0.0008,
      "weight_decay": 0.0001,
      "dropout": 0.05,
      "validation_fraction": 0.15,
      "patience": 20,
      "min_delta": 0.000001
    }
  },
  "outputs": {
    "output_dir": "results/external_perturbation_v1"
  }
