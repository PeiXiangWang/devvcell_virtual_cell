{
  "project": "DevVCell-cell-level-v1",
  "seed": 42,
  "raw_h5ad_path": "data/scLine_pro.h5ad",
  "processed_subset_path": "data/processed/cell_level_subset_v1.h5ad",
  "results_dir": "results/cell_level_v1",
  "stages": [
    12,
    13,
    14,
    15,
    16,
    17,
    18,
    19
  ],
  "heldout_target_stages": [
    15,
    18
  ],
  "max_cells_per_stage_system": 800,
  "systems": {
    "neural": {
      "obs_column": "cell_type",
      "patterns": [
        "neural",
        "neuron",
        "glia"
      ]
    },
    "mesoderm_muscle": {
      "obs_column": "author_major_cell_cluster",
      "patterns": [
        "Mesoderm",
        "Muscle_cells",
        "Intermediate_neuronal_progenitors"
      ]
    },
    "erythroid": {
      "obs_column": "cell_type",
      "patterns": [
        "erythroid"
      ]
    }
  },
  "model": {
    "latent_dim": 64,
    "max_pairs_per_transition": 800,
    "pairing": {
      "method": "sinkhorn",
      "target_pool_multiplier": 2,
      "sinkhorn_epsilon": 0.12,
      "sinkhorn_iterations": 120
    },
    "ridge_alpha": 1.0,
    "mmd_max_cells": 300,
    "mlp": {
      "enabled": true,
      "hidden_dim": 128,
      "epochs": 80,
      "batch_size": 512,
      "learning_rate": 0.001,
      "weight_decay": 0.0001
    },
    "context_residual_mlp": {
      "enabled": true,
      "hidden_dim": 192,
      "epochs": 200,
      "batch_size": 512,
      "learning_rate": 0.0008,
      "weight_decay": 0.0001,
      "dropout": 0.05,
      "validation_fraction": 0.15,
      "patience": 24,
      "min_delta": 1e-05
    }
  },
  "stimulus": {
    "top_n_tfs": 12,
    "max_cells_per_stage_system": 200,
    "stimulus_strength": 0.35,
    "top_target_genes": 80,
    "system_edge_weight": 0.45,
    "global_grn_weight": 0.55,
    "system_map": {
      "neural": [
        "neural cell"
      ],
      "mesoderm_muscle": [
        "myoblast",
        "myotube",
        "muscle precursor cell",
        "cardiac muscle cell"
      ],
      "erythroid": [
        "erythroid progenitor cell",
        "primitive erythroid progenitor",
        "hematopoietic stem cell"
      ]
    }
  }
}