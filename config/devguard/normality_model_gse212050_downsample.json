{
  "seed": 42,
  "input_h5ad": "data/processed/devguard/GSE212050_downsample_15000.h5ad",
  "output_dir": "results/devguard_real/GSE212050_downsample/normality_reference",
  "model_output": "results/devguard_real/GSE212050_downsample/normality_reference/devguard_normality_model.joblib",
  "embedding": {
    "method": "truncated_svd",
    "n_hvg": 3000,
    "latent_dim": 30,
    "normalize_total": 10000,
    "log1p": true
  },
  "reference_grouping": {
    "time_column": "time_point",
    "time_numeric_column": "time_numeric",
    "lineage_column": "lineage",
    "min_cells_per_group": 80
  },
  "splits": {
    "train_fraction": 0.5,
    "calibration_fraction": 0.25,
    "test_fraction": 0.25
  },
  "sample_split": {
    "strategy": "sample",
    "unit_column": "sample_id",
    "allow_cell_fallback": true
  },
  "score_methods": ["knn_distance", "mahalanobis"],
  "knn": {
    "k": 15
  },
  "mahalanobis": {
    "regularization": 0.05
  },
  "alpha": 0.05
}
