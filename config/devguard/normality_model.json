{
  "seed": 42,
  "input_h5ad": "data/processed/devguard/devguard_quick_mouse.h5ad",
  "output_dir": "results/devguard/normality_reference",
  "model_output": "results/devguard/normality_reference/devguard_normality_model.joblib",
  "embedding": {
    "method": "truncated_svd",
    "n_hvg": 3000,
    "latent_dim": 20,
    "normalize_total": 10000,
    "log1p": true
  },
  "reference_grouping": {
    "time_column": "time_point",
    "time_numeric_column": "time_numeric",
    "lineage_column": "lineage",
    "min_cells_per_group": 30
  },
  "splits": {
    "train_fraction": 0.6,
    "calibration_fraction": 0.2,
    "test_fraction": 0.2
  },
  "score_methods": ["knn_distance", "mahalanobis"],
  "knn": {
    "k": 15
  },
  "mahalanobis": {
    "regularization": 0.01
  },
  "alpha": 0.05
}
