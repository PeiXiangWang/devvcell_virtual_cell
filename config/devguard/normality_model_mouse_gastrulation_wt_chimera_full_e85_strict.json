{
  "seed": 42,
  "input_h5ad": "data/processed/devguard/MouseGastrulationData_wt_chimera_full.h5ad",
  "output_dir": "results/devguard_real/MouseGastrulationData_wt_chimera_full_e85_strict/normality_reference",
  "model_output": "results/devguard_real/MouseGastrulationData_wt_chimera_full_e85_strict/normality_reference/devguard_normality_model.joblib",
  "embedding": {
    "method": "truncated_svd",
    "n_hvg": 3000,
    "latent_dim": 30,
    "normalize_total": 10000,
    "log1p": true
  },
  "reference_grouping": {
    "time_column": "time_point",
    "time_numeric_column": "time_numeric",
    "lineage_column": "lineage",
    "min_cells_per_group": 100
  },
  "splits": {
    "train_fraction": 0.34,
    "calibration_fraction": 0.33,
    "test_fraction": 0.33
  },
  "sample_split": {
    "strategy": "sample",
    "unit_column": "sample_id",
    "allow_cell_fallback": false,
    "min_units_per_group": 6
  },
  "score_methods": ["knn_distance", "mahalanobis"],
  "knn": {
    "k": 15
  },
  "mahalanobis": {
    "regularization": 0.05
  },
  "alpha": 0.05
}
