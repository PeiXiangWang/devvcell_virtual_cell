{
  "timeseries": "results/devspectrum/timeseries/stage_lineage_module_timeseries.csv",
  "output_dir": "results/devspectrum/missing_stage_reconstruction",
  "holdout_strategy": "leave_one_timepoint_out",
  "baseline_methods": ["mean", "linear", "spline"],
  "spectral_methods": ["dct", "wavelet", "dct_wavelet"],
  "metrics": ["mse", "mae", "pearson", "spearman"],
  "basis_config": {
    "dct": {
      "max_basis": 4
    },
    "wavelet": {
      "max_level": 2
    },
    "spline": {
      "degree": 3
    }
  },
  "bootstrap": {
    "level": "sample",
    "n_bootstrap": 200,
    "seed": 42
  }
}
