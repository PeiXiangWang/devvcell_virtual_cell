{
  "project": "DevVCell niche-aware virtual cell",
  "version": "2026-05-05",
  "seed": 42,
  "input": {
    "embryo_h5ad": "data/scLine_pro.h5ad",
    "embryo_manifold_cells": "results/response_recovery/tables/embryo_manifold_cells.parquet",
    "stage_column": "development_stage",
    "cell_type_column": "cell_type",
    "donor_column": "donor_id",
    "sex_column": "sex",
    "major_cluster_column": "author_major_cell_cluster"
  },
  "output": {
    "root": "results/niche_context",
    "tables": "results/niche_context/tables",
    "figures": "results/niche_context/figures",
    "niche_signature_by_stage_donor": "results/niche_context/tables/niche_signature_by_stage_donor.csv",
    "tbx4_glis3_niche_case": "results/niche_context/tables/tbx4_glis3_niche_case.csv",
    "cell_autonomous_vs_niche": "results/niche_context/tables/cell_autonomous_vs_niche_scores.csv"
  },
  "case_study": {
    "niche_marker_gene": "Tbx4",
    "target_gene": "Glis3",
    "target_cell_type_keywords": ["germ", "pgc", "primordial"],
    "niche_cell_type_keywords": ["mesoderm", "gonad", "limb", "lateral plate"],
    "high_expression_quantile": 0.85,
    "min_cells_per_stage_donor": 20
  },
  "niche_features": {
    "cell_type_composition": true,
    "major_cluster_composition": true,
    "donor_level_marker_mean": true,
    "stage_level_cooccurrence": true,
    "ligand_receptor_modules": false,
    "spatial_validation": "optional"
  },
  "sampling": {
    "max_cells_total": 120000,
    "max_cells_per_stage_celltype": 600
  }
}
